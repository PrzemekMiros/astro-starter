---
const { title, lead, tags, date, readingTimeMinutes } = Astro.props;
const { site, url } = Astro;

const formattedDate = date
  ? new Date(date).toLocaleDateString("pl-PL", {
      year: "numeric",
      month: "2-digit",
      day: "2-digit",
    })
  : null;

const readingTime = Number.isFinite(readingTimeMinutes)
  ? Math.max(1, Number(readingTimeMinutes))
  : null;

const readingTimeLabel = readingTime
  ? `${readingTime} ${readingTime === 1 ? "minuta" : readingTime >= 2 && readingTime <= 4 ? "minuty" : "minut"} czytania`
  : null;

const articleUrl = site ? new URL(url.pathname, site).toString() : url.toString();
const encodedArticleUrl = encodeURIComponent(articleUrl);
const encodedTitle = encodeURIComponent(title ?? "");
const facebookShareUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodedArticleUrl}`;
const xShareUrl = `https://twitter.com/intent/tweet?url=${encodedArticleUrl}&text=${encodedTitle}`;
const mailShareUrl = `mailto:?subject=${encodedTitle}&body=${encodedTitle}%0A${encodedArticleUrl}`;
---

<section class="relative pt-24 pb-0 md:pt-34 md:pb-8">
  <div class="pointer-events-none absolute inset-y-0 left-1/2 w-screen -translate-x-1/2 bg-gray-50"></div>

  <div class="grid gap-4 md:gap-10 lg:grid-cols-[250px_minmax(0,1fr)_280px]">
    <div></div>

    <div>
      <div class="relative space-y-4 mx-auto">
        <div class="text-[8px] md:text-[10px] uppercase tracking-[0.1em] text-gray-400 mb-3 md:mb-6 font-semibold">
          <span class="text-gray">Artykuly</span>
          <span class="text-[var(--accent)]"> • </span>
          <span class="text-gray">{title}</span>
        </div>

        <h1 class="text-2xl sm:text-3xl md:text-4xl lg:text-5xl font-semibold text-black/90">
          {title}
        </h1>

        {lead ? <p class="text-base md:text-lg text-black/70 leading-relaxed">{lead}</p> : null}

        <div class="flex flex-wrap gap-x-8 gap-y-2 pt-4 mt-4 md:pt-8 md:mt-8 border-t border-black/20 font-semibold text-[8px] md:text-[10px] tracking-[0.15em] uppercase">
          {tags && tags.length > 0 ? <div class="text-gray-400"><span class="text-gray">{tags[0]}</span></div> : null}
          {formattedDate ? <div class="text-gray-400 hidden md:block"><span class="text-gray">{formattedDate}</span></div> : null}
          {readingTimeLabel ? <div class="text-gray-400">{readingTimeLabel}</div> : null}
        </div>
      </div>
    </div>

    <div class="relative flex md:flex-col md:items-end gap-2 mt-4 md:mt-12 text-black/70">
      <a href={facebookShareUrl} target="_blank" rel="noopener noreferrer" aria-label="Udostepnij na Facebooku" class="block w-12 h-12 transition hover:text-[var(--accent)] rounded-full border border-gray-500 p-3">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M13.5 8.5V7c0-1.1.9-2 2-2h2V2h-3c-2.8 0-5 2.2-5 5v1.5H7v3h2.5V22h3v-10.5h3l.5-3h-3.5z"></path>
        </svg>
      </a>

      <a href={xShareUrl} target="_blank" rel="noopener noreferrer" aria-label="Udostepnij na X" class="block w-12 h-12 transition hover:text-[var(--accent)] rounded-full border border-gray-500 p-3">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.9 2H22l-6.8 7.8L23 22h-6.4l-4.8-6.1L6.2 22H3l7.3-8.5L1 2h6.6l4.3 5.5L18.9 2z"></path>
        </svg>
      </a>

      <a href={mailShareUrl} aria-label="Wyslij link mailem" class="block w-12 h-12 transition hover:text-[var(--accent)] rounded-full border border-gray-500 p-3">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="5" width="18" height="14" rx="2"></rect>
          <path d="M3 7l9 6 9-6"></path>
        </svg>
      </a>

      <button type="button" data-copy-link={articleUrl} aria-label="Kopiuj link artykulu" class="block w-12 h-12 transition hover:text-[var(--accent)] rounded-full border border-gray-500 p-3">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="9" y="9" width="13" height="13" rx="2"></rect>
          <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
        </svg>
      </button>
    </div>
  </div>
</section>

<script is:inline>
  const copyButtons = document.querySelectorAll("[data-copy-link]");
  copyButtons.forEach((button) => {
    button.addEventListener("click", async () => {
      const link = button.getAttribute("data-copy-link");
      if (!link) return;

      try {
        await navigator.clipboard.writeText(link);
        button.classList.add("text-[var(--accent)]");
        setTimeout(() => button.classList.remove("text-[var(--accent)]"), 1200);
      } catch {
        window.prompt("Skopiuj link:", link);
      }
    });
  });
</script>
